{
  "name": "app",
  "version": "0.0.0",
  "type": "module",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "vite preview",
    "secret:sync": "bash scripts/set-secrets.sh .env.production",
    "preview": "vite build && wrangler pages dev ./dist",
    "deploy": "pnpm secret:sync && vite build && wrangler pages deploy ./dist",
    "lint": "concurrently \"pnpm:lint:*\"",
    "lint:tsc": "tsc --noEmit",
    "lint:biome": "biome check .",
    "fmt": "concurrently \"pnpm:fmt:*\"",
    "fmt:biome": "biome check --write --unsafe ."
  },
  "dependencies": {
    "@packages/db": "workspace:*",
    "@tanstack/react-router": "1.145.11",
    "@tanstack/react-start": "1.145.11",
    "lucide-react": "0.509.0",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@packages/biome-config": "workspace:*",
    "@tailwindcss/vite": "4.1.18",
    "@tsconfig/strictest": "2.0.5",
    "@types/node": "22.13.1",
    "@types/react": "19.1.8",
    "@types/react-dom": "19.1.6",
    "@vitejs/plugin-react": "5.1.2",
    "concurrently": "9.0.1",
    "dotenv-cli": "8.0.0",
    "tailwindcss": "4.1.18",
    "typescript": "5.6.2",
    "vite": "7.3.1",
    "vite-tsconfig-paths": "5.1.4",
    "wrangler": "4.14.4"
  }
}
