{
  "name": "app",
  "version": "0.0.0",
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "secret:sync": "bash scripts/set-secrets.sh .env.production",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "pnpm secret:sync && opennextjs-cloudflare build && dotenv -e .env.production -- opennextjs-cloudflare deploy",
    "lint": "concurrently \"pnpm:lint:*\"",
    "lint:tsc": "tsc --noEmit",
    "lint:oxlint": "oxlint .",
    "fmt": "concurrently \"pnpm:fmt:*\"",
    "fmt:oxfmt": "oxfmt --write ."
  },
  "dependencies": {
    "@opennextjs/cloudflare": "1.0.1",
    "@packages/db": "workspace:*",
    "lucide-react": "0.509.0",
    "next": "15.3.2",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.1.7",
    "@tsconfig/strictest": "2.0.5",
    "@types/node": "22.13.1",
    "@types/react": "19.1.8",
    "@types/react-dom": "19.1.6",
    "concurrently": "9.0.1",
    "dotenv-cli": "8.0.0",
    "tailwindcss": "4.1.7",
    "typescript": "6.0.1-rc",
    "wrangler": "4.14.4"
  }
}
