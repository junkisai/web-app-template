{
  "name": "app",
  "version": "0.0.0",
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build && tsc --noEmit",
    "preview": "vite preview",
    "cf:set-env": "bash scripts/set-secrets.sh .env.production",
    "lint": "concurrently \"pnpm:lint:*\"",
    "lint:tsc": "tsc --noEmit",
    "lint:oxlint": "oxlint .",
    "fmt": "concurrently \"pnpm:fmt:*\"",
    "fmt:oxfmt": "oxfmt --write ."
  },
  "dependencies": {
    "@cloudflare/vite-plugin": "1.30.1",
    "@packages/auth": "workspace:*",
    "@packages/db": "workspace:*",
    "@tailwindcss/vite": "4.2.2",
    "@tanstack/react-router": "1.168.3",
    "@tanstack/react-start": "1.167.6",
    "@vitejs/plugin-react": "6.0.1",
    "lucide-react": "0.509.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "vite": "8.0.10"
  },
  "devDependencies": {
    "@tsconfig/strictest": "2.0.8",
    "@types/node": "22.13.1",
    "@types/react": "19.1.8",
    "@types/react-dom": "19.1.6",
    "concurrently": "9.2.1",
    "dotenv-cli": "8.0.0",
    "tailwindcss": "4.2.2",
    "typescript": "6.0.3",
    "wrangler": "4.78.0"
  }
}
